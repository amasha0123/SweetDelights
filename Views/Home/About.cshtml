@{
    ViewData["Title"] = "About Us";
}

<div class="container mt-5">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h1 class="text-pink fw-bold mb-4">About Sweet Delights</h1>
            <h4 class="text-brown mb-3">Our History</h4>
            <p>Founded in 2020, Sweet Delights started as a small kitchen dream and has blossomed into the city's favorite spot for artisan cakes. We believe in baking from scratch using only the finest ingredients.</p>
            
            <h4 class="text-brown mb-3 mt-4">Our Mission</h4>
            <p>To bring joy to every celebration through beautifully crafted and incredibly delicious cakes. We put love and passion into every single slice.</p>
        </div>
        <div class="col-md-6">
            <div class="card cake-card">
                <img src="https://images.unsplash.com/photo-1555507036-ab1e4006aaeb?q=80&w=1000&auto=format&fit=crop" class="img-fluid rounded" alt="Bakery Team">
            </div>
        </div>
    </div>

    <div class="row mt-5 mb-5 text-center">
        <h3 class="text-pink fw-bold mb-4">Meet Our Team</h3>
        <div class="col-md-4">
            <h5>Jane Doe</h5>
            <p class="text-muted">Master Baker</p>
        </div>
        <div class="col-md-4">
            <h5>John Smith</h5>
            <p class="text-muted">Pastry Chef</p>
        </div>
        <div class="col-md-4">
            <h5>Emily Rose</h5>
            <p class="text-muted">Cake Decorator</p>
        </div>
    </div>
</div>
