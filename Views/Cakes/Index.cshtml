@model IEnumerable<SweetDelights.Models.Cake>

@{
    ViewData["Title"] = "Our Cakes";
}

<h1 class="text-pink fw-bold text-center mt-4 mb-5">Our Cake Menu</h1>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card cake-card h-100">
                <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-pink fw-bold">@item.Name</h5>
                    <p class="text-muted small mb-2">@item.Category</p>
                    <p class="card-text flex-grow-1">@item.Description</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="fs-5 fw-bold text-brown">@item.Price.ToString("C")</span>
                        <a asp-action="Details" asp-route-id="@item.CakeId" class="btn btn-outline-pink rounded-pill">View Details</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
