<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sweet Delights Cake Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    
    <!-- 3D Spline Viewer -->
    <script type="module" src="https://unpkg.com/@splinetool/viewer@1.0.51/build/spline-viewer.js"></script>
</head>
<body>
    <header class="fixed-top w-100">
        <nav class="navbar navbar-expand-sm navbar-light">
            <div class="container-fluid px-5">
                <a class="navbar-brand fw-bold text-pink d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="fs-2">🧁</span> Sweet Delights
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav me-4">
                        <li class="nav-item">
                            <a class="nav-link text-brown" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-brown" asp-controller="Cakes" asp-action="Index">Menu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-brown" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-brown" asp-controller="Contact" asp-action="Index">Contact</a>
                        </li>
                    </ul>
                    <a class="btn btn-outline-pink rounded-pill px-4" asp-controller="Admin" asp-action="Index">Admin Portal</a>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container-fluid px-4" style="margin-top: 100px;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-5 py-5" style="background: rgba(255,255,255,0.5); backdrop-filter: blur(10px);">
        <div class="container text-center">
            <h4 class="text-pink fw-bold mb-3">Sweet Delights</h4>
            <p class="text-brown mb-0">&copy; @DateTime.Now.Year - Crafted with ❤️ and Sugar.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- GSAP for advanced animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <!-- Vanilla Tilt for 3D card effects -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.0/vanilla-tilt.min.js"></script>
    
    <script>
        // Initialize 3D Card tilt
        VanillaTilt.init(document.querySelectorAll(".cake-card"), {
            max: 15,
            speed: 400,
            glare: true,
            "max-glare": 0.3,
        });

        // Initialize GSAP Scroll animations
        gsap.registerPlugin(ScrollTrigger);

        gsap.utils.toArray('.gsap-fade-up').forEach(element => {
            gsap.from(element, {
                scrollTrigger: {
                    trigger: element,
                    start: "top 80%",
                    toggleActions: "play none none reverse"
                },
                y: 50,
                opacity: 0,
                duration: 1,
                ease: "power3.out"
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
