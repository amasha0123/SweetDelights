@model IEnumerable<SweetDelights.Models.Cake>

@{
    ViewData["Title"] = "Admin - Cake Management";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h1 class="text-pink fw-bold">Cake Management</h1>
    <a asp-action="Create" class="btn btn-pink rounded-pill px-4">Add New Cake</a>
</div>

<div class="table-responsive">
    <table class="table table-hover table-striped border">
        <thead class="bg-cream">
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td class="align-middle">
                        <img src="@item.ImageUrl" alt="@item.Name" style="width: 50px; height: 50px; object-fit: cover;" class="rounded-circle" />
                    </td>
                    <td class="align-middle fw-bold">@item.Name</td>
                    <td class="align-middle">@item.Category</td>
                    <td class="align-middle">@item.Price.ToString("C")</td>
                    <td class="align-middle">
                        @(item.IsAvailable ? "Yes" : "No")
                    </td>
                    <td class="align-middle">
                        <a asp-action="Edit" asp-route-id="@item.CakeId" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.CakeId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
